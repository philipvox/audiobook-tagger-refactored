{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Audiobook Tagger",
  "version": "1.0.0",
  "identifier": "com.audiobook.tagger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Audiobook Tagger",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost blob: data:; connect-src ipc: http://ipc.localhost https://*.vito0912.de https://*.audible.com https://*.audible.co.uk https://itunes.apple.com https://www.googleapis.com https://*.openlibrary.org https://api.openai.com",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$HOME/Library/Application Support/Audiobook Tagger/**"]
      },
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main app permissions",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default",
            "dialog:allow-open",
            "dialog:allow-save",
            "dialog:allow-message",
            "dialog:allow-ask",
            "dialog:allow-confirm"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "exceptionDomain": null,
      "signingIdentity": "Developer ID Application: Philip Glenn (DX7MCA54J8)"
    }
  }
}